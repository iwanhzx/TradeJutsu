{
  "name": "tradejutsu",
  "private": true,
  "scripts": {
    "dev": "concurrently -n BE,FE -c blue,green \"cd backend && uvicorn app.main:app --reload --port 8000\" \"cd frontend && npm run dev\"",
    "backend": "cd backend && uvicorn app.main:app --reload --port 8000",
    "frontend": "cd frontend && npm run dev",
